# =========================================================
# 🔧 FIREFOX PROFILE PATH - HOW TO FIND IT
#
# METHOD 1:
# 1. Open Firefox
# 2. Go to: about:support
# 3. Find "Profile Folder"
# 4. Click "Open Folder"
#
# METHOD 2:
# 1. Open Firefox
# 2. Go to: about:profiles
# 3. Copy "Root Directory"
# =========================================================

# ================= USER INPUT =================
$profilePath = "C:\Users\sauli\AppData\Roaming\Mozilla\Firefox\Profiles\5o4cs8f1.default-release-1779183460843"
# ==============================================

# =========================================================
# FIREFOX POLICY DIRECTORY
# =========================================================

$policyDir = "C:\Program Files\Mozilla Firefox\distribution"

if (!(Test-Path (Split-Path $policyDir -Parent))) {
    $policyDir = "C:\Program Files (x86)\Mozilla Firefox\distribution"
}

# =========================================================
# SAFETY CHECKS
# =========================================================

if ([string]::IsNullOrWhiteSpace($profilePath)) {
    Write-Host "`n❌ PROFILE PATH IS EMPTY" -ForegroundColor Red
    Write-Host "👉 Open about:support and copy your profile path" -ForegroundColor Yellow
    exit 1
}

if (!(Test-Path $profilePath)) {
    Write-Host "`n❌ PROFILE PATH NOT FOUND" -ForegroundColor Red
    Write-Host "👉 Check about:support → Profile Folder" -ForegroundColor Yellow
    exit 1
}

# =========================================================
# BACKUPS
# =========================================================

$backup = Get-Date -Format "yyyy-MM-dd_HH-mm"

$userjsPath = Join-Path $profilePath "user.js"

New-Item -ItemType Directory -Force -Path $policyDir | Out-Null

if (Test-Path "$policyDir\policies.json") {
    Copy-Item `
        "$policyDir\policies.json" `
        "$policyDir\policies.json.bak_$backup" `
        -Force
}

if (Test-Path $userjsPath) {
    Copy-Item `
        $userjsPath `
        "$userjsPath.bak_$backup" `
        -Force
}

# =========================================================
# POLICIES.JSON
# =========================================================

Set-Content "$policyDir\policies.json" @'
{
  "policies": {

    "DisableTelemetry": true,
    "DisableFirefoxAccounts": false,
    "DisableFirefoxStudies": true,
    "DisablePocket": true,
    "DisableCrashReporter": true,
    "DisableExtensionRecommendations": true,
    "DisableFirefoxView": true,

    "HttpsOnlyMode": "force_enabled",

    "DNSOverHTTPS": {
      "Enabled": true,
      "ProviderURL": "https://cloudflare-dns.com/dns-query",
      "Fallback": true,
      "Locked": false
    }
  }
}
'@ -Encoding UTF8

