Write-Host "`n🚀 FIREFOX CONFIG APPLIED SUCCESSFULLY" -ForegroundColor Green
Write-Host "🔁 Restart Firefox" -ForegroundColor Yellow
Write-Host "📦 Backup timestamp: $backup" -ForegroundColor Cyan
